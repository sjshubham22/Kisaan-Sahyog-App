{
  "name": "kisaan-sahyog",
  "version": "1.0.0",
  "description": "Kisaan Sahyog - Farmer Advisory System web application",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build": "npm run client-install && cd client && npm run build",
    "client-install": "cd client && npm install",
    "client-dev": "cd client && npm run dev",
    "install-all": "npm install && npm run client-install",
    "dev-all": "npx concurrently \"npm run dev\" \"npm run client-dev\""
  },
  "dependencies": {
    "@google/genai": "latest",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
